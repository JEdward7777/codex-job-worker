 # =============================================================================
# Monitor Process Environment Variables
# =============================================================================
# Copy this file to .env and fill in the required values:
#   cp .env.template .env
#
# The .env file is git-ignored and should NEVER be committed.
# =============================================================================

# ---------------------------------------------------------------------------
# REQUIRED
# ---------------------------------------------------------------------------

# GitLab access token for scanning jobs
# Needs scopes: read_api, read_repository
GITLAB_TOKEN=your_gitlab_token_here

# Vast.ai API key (required when CLOUD_PROVIDER=vast)
# Get yours at: https://cloud.vast.ai/account/
VAST_API_KEY=your_vast_api_key_here

# ---------------------------------------------------------------------------
# OPTIONAL (uncomment and change to override defaults)
# ---------------------------------------------------------------------------

# Cloud provider to use: 'vast' (default) or 'skypilot'
# CLOUD_PROVIDER=vast

# GitLab server URL
# GITLAB_URL=https://git.genesisrnd.com

# Maximum number of concurrent GPU workers (default: 5)
# MAX_WORKERS=5

# Minimum workers to keep running even with 0 jobs (default: 0)
# Useful for testing or keeping warm capacity
# MIN_WORKERS=0

# Number of active jobs per worker for the scaling formula (default: 4)
# ceil(active_jobs / JOBS_PER_WORKER) = desired workers
# JOBS_PER_WORKER=4

# Minutes of idle time before auto-teardown (default: 1)
# Workers auto-terminate after being idle for this many minutes.
# IDLE_MINUTES=1

# Seconds before tearing down clusters stuck in INIT state (default: 1800 = 30 min)
# INIT_TIMEOUT=1800

# Path to the SkyPilot worker YAML task file (default: skypilot_worker.yaml)
# WORKER_YAML=skypilot_worker.yaml

# Log file path (default: monitor.log)
# LOG_FILE=monitor.log

# Hours a project must have no actionable jobs before the worker unshares
# itself from it (default: 24). Set to 0 to disable stale project cleanup.
# PROJECT_UNSHARE_HOURS=24

# Path to the JSON file tracking stale projects (default: stale_projects.json)
# STALE_PROJECTS_FILE=stale_projects.json

# Hours after which a claimed job with no heartbeat update is considered stale
# and eligible for re-claiming by a new worker (default: 24).
# This prevents jobs from being stuck forever when a GPU worker is killed.
# Both the monitor (for VM scaling) and the worker (for re-claiming) use this.
# CLAIM_TIMEOUT_HOURS=24

# Maximum number of times a stale job can be re-claimed before being marked
# as permanently failed (default: 3). Prevents infinite retry loops for
# fundamentally broken jobs.
# MAX_JOB_RETRIES=3

# Hours a running instance must have no active job before being destroyed
# (default: 2). Catches zombie instances where the worker process died but
# the cloud instance stayed alive (e.g., after a Vast.ai container restart).
# Uses a two-pass approach: first pass records the instance as orphaned in a
# JSON file, second pass (after the grace period) destroys it.
# Set to 0 to disable orphan instance cleanup.
# ORPHAN_INSTANCE_HOURS=2

# Path to the JSON file tracking orphan instances (default: orphan_instances.json)
# ORPHAN_INSTANCES_FILE=orphan_instances.json
